            "GET",
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ],
          "default": "POST",
          "title": "HTTP Method",
          "description": "HTTP method that triggers the webhook"
        },
        "authentication": {
          "type": "string",
          "enum": [
            "none",
            "basic",
            "bearer",
            "hmac",
            "query_param"
          ],
          "default": "none",
          "title": "Authentication Method",
          "description": "How to authenticate incoming webhook requests"
        },
        "auth_config": {
          "type": "object",
          "title": "Authentication Configuration",
          "description": "Configuration for the selected authentication method",
          "properties": {
            "username": {
              "type": "string",
              "title": "Username"
            },
            "password": {
              "type": "string",
              "title": "Password",
              "format": "password"
            },
            "token": {
              "type": "string",
              "title": "Bearer Token",
              "format": "password"
            },
            "secret": {
              "type": "string",
              "title": "HMAC Secret",
              "format": "password"
            },
            "param_name": {
              "type": "string",
              "title": "Query Parameter Name"
            },
            "param_value": {
              "type": "string",
              "title": "Expected Parameter Value"
            }
          }
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "Required Fields",
          "description": "Fields that must be present in webhook payload"
        },
        "response_config": {
          "type": "object",
          "title": "Response Configuration",
          "properties": {
            "status_code": {
              "type": "integer",
              "default": 200,
              "title": "Response Status Code"
            },
            "response_body": {
              "type": "object",
              "title": "Response Body",
              "default": {
                "status": "received"
              }
            }
          }
        }
      },
      "required": [
        "path"
      ]
    },
    "version": "1.0.0",
    "created_at": "2026-01-25T22:04:01.982768",
    "updated_at": "2026-01-25T22:04:01.982768"
  },
  "http_request": {
