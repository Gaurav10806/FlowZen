  "schedule_trigger": {
    "node_type": "schedule_trigger",
    "display_name": "Schedule Trigger",
    "description": "Triggers workflow on a schedule using cron expressions",
    "category": "triggers",
    "python_class": "workflows.nodes.trigger_nodes.ScheduleTriggerNode",
    "module_path": "workflows.nodes.trigger_nodes",
    "status": "enabled",
    "parameter_schema": {
      "type": "object",
      "properties": {
        "cron_expression": {
          "type": "string",
          "title": "Cron Expression",
          "description": "Cron expression for schedule (e.g., '0 9 * * 1-5' for weekdays at 9 AM)",
          "default": "0 0 * * *"
        },
        "timezone": {
          "type": "string",
          "title": "Timezone",
          "description": "Timezone for schedule execution",
          "default": "UTC",
          "enum": [
            "UTC",
            "America/New_York",
            "America/Los_Angeles",
            "Europe/London",
            "Europe/Paris",
            "Asia/Tokyo"
          ]
        },
        "static_data": {
          "type": "object",
          "title": "Static Data",
          "description": "Static data to include with each scheduled execution",
          "default": {}
        },
        "enabled": {
          "type": "boolean",
          "title": "Enabled",
          "description": "Whether the schedule is active",
          "default": true
        }
      },
      "required": [
        "cron_expression"
      ]
    },
    "version": "1.0.0",
    "created_at": "2026-01-25T22:04:01.950258",
    "updated_at": "2026-01-25T22:04:01.950258"
  },
  "fork": {
    "node_type": "fork",
    "display_name": "Fork",
    "description": "Split execution into multiple parallel branches",
    "category": "utilities",
    "python_class": "workflows.nodes.parallel_nodes.ForkNode",
    "module_path": "workflows.nodes.parallel_nodes",
    "status": "enabled",
    "parameter_schema": {
      "type": "object",
      "properties": {
        "branch_count": {
          "type": "integer",
          "title": "Branch Count",
          "description": "Number of parallel branches to create",
          "minimum": 1,
          "maximum": 10,
          "default": 2
        },
        "branch_names": {
          "type": "array",
          "title": "Branch Names",
          "description": "Optional names for branches (for logging and debugging)",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "maxItems": 10
        },
        "execution_mode": {
          "type": "string",
          "enum": [
            "sync",
            "async"
          ],
          "title": "Execution Mode",
          "description": "How to execute branches",
          "default": "async"
        },
        "timeout_ms": {
          "type": "integer",
          "title": "Timeout (milliseconds)",
          "description": "Maximum time to wait for all branches",
          "minimum": 1000,
          "maximum": 300000,
          "default": 30000
        },
        "failure_strategy": {
          "type": "string",
          "enum": [
            "fail_fast",
            "continue_on_error",
            "wait_for_all"
          ],
          "title": "Failure Strategy",
          "description": "How to handle branch failures",
          "default": "fail_fast"
        }
      },
      "required": [
        "branch_count"
      ],
      "additionalProperties": false
    },
    "version": "1.0.0",
    "created_at": "2026-01-25T22:04:01.951274",
    "updated_at": "2026-01-25T22:04:01.951274"
  },
  "merge": {
    "node_type": "merge",
    "display_name": "Merge",
    "description": "Merge results from multiple parallel branches",
    "category": "utilities",
    "python_class": "workflows.nodes.parallel_nodes.MergeNode",
    "module_path": "workflows.nodes.parallel_nodes",
    "status": "enabled",
    "parameter_schema": {
      "type": "object",
      "properties": {
        "merge_strategy": {
          "type": "string",
          "enum": [
            "all",
            "first_success",
            "majority",
            "any"
          ],
          "title": "Merge Strategy",
          "description": "How to wait for branch completion",
          "default": "all"
        },
        "merge_mode": {
          "type": "string",
          "enum": [
            "array",
            "object",
            "flatten",
            "first"
          ],
          "title": "Merge Mode",
          "description": "How to combine branch results",
          "default": "array"
        },
        "timeout_ms": {
          "type": "integer",
          "title": "Timeout (milliseconds)",
          "description": "Maximum time to wait for branches",
          "minimum": 1000,
          "maximum": 600000,
          "default": 60000
        },
        "failure_strategy": {
          "type": "string",
          "enum": [
            "fail_on_any",
            "partial_success",
            "ignore_failures"
          ],
          "title": "Failure Strategy",
          "description": "How to handle branch failures",
          "default": "partial_success"
        },
        "required_branches": {
          "type": "array",
          "title": "Required Branches",
          "description": "Specific branches that must succeed",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "version": "1.0.0",
    "created_at": "2026-01-25T22:04:01.952284",
    "updated_at": "2026-01-25T22:04:01.952284"
  },
  "if_else": {
    "node_type": "if_else",
    "display_name": "IF / ELSE",
    "description": "Simple IF/ELSE conditional logic",
    "category": "utilities",
    "python_class": "workflows.nodes.conditional_node.IfElseNode",
    "module_path": "workflows.nodes.conditional_node",
    "status": "enabled",
    "parameter_schema": {
      "type": "object",
      "properties": {
        "left_operand": {
          "type": "string",
          "title": "Left Operand",
          "description": "Left side of comparison (field path, template, or literal value)",
          "examples": [
            "user.email",
            "{{order.total}}",
            "100",
            "active"
          ]
        },
        "operator": {
          "type": "string",
          "enum": [
            "equals",
            "not_equals",
            "greater_than",
            "greater_equal",
            "less_than",
            "less_equal",
            "contains",
            "not_contains",
            "starts_with",
            "ends_with",
            "exists",
            "not_exists",
            "is_empty",
            "is_not_empty",
            "regex_match",
            "in_list",
            "not_in_list"
          ],
          "title": "Operator",
          "description": "Comparison operator",
          "default": "equals"
        },
        "right_operand": {
          "type": "string",
          "title": "Right Operand",
          "description": "Right side of comparison (field path, template, or literal value)",
          "examples": [
            "admin@example.com",
            "{{config.threshold}}",
            "0",
            "true"
          ]
        },
        "case_sensitive": {
          "type": "boolean",
          "title": "Case Sensitive",
          "description": "Whether string comparisons should be case sensitive",
          "default": true
        }
      },
      "required": [
        "left_operand",
        "operator"
      ],
      "additionalProperties": false
    },
    "version": "1.0.0",
    "created_at": "2026-01-25T22:04:01.953287",
    "updated_at": "2026-01-25T22:04:01.953287"
  },
