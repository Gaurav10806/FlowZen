{
  "plugin_id": "enhanced-http-node",
  "name": "Enhanced HTTP Request Node",
  "version": "1.2.0",
  "description": "An advanced HTTP request node with retry logic, authentication, response validation, and comprehensive error handling for robust API integrations.",
  "author": {
    "name": "John Developer",
    "email": "john@example.com",
    "website": "https://johndeveloper.com",
    "organization": "Example Corp"
  },
  "plugin_type": "node",
  "main_module": "main.py",
  "provides": {
    "nodes": ["EnhancedHttpNode"],
    "tools": ["enhanced_http_tool"],
    "apis": [],
    "triggers": []
  },
  "permissions": {
    "network_access": true,
    "file_system_access": false,
    "database_access": false,
    "external_apis": ["*"],
    "allowed_imports": [
      "requests",
      "urllib3",
      "json",
      "time",
      "datetime",
      "base64",
      "hashlib",
      "hmac"
    ],
    "resource_limits": {
      "max_memory_mb": 100,
      "max_execution_time_seconds": 60,
      "max_network_requests_per_minute": 120
    },
    "custom_permissions": [
      "http_authentication",
      "response_caching"
    ]
  },
  "trust_level": "community",
  "requires_signature": true,
  "compatibility": {
    "min_platform_version": "1.0.0",
    "max_platform_version": "2.0.0",
    "python_version": ">=3.8",
    "required_features": [
      "http_nodes",
      "network_access",
      "retry_logic"
    ],
    "conflicting_plugins": []
  },
  "dependencies": [
    {
      "name": "requests",
      "version": ">=2.25.0",
      "optional": false,
      "source": "pypi"
    },
    {
      "name": "urllib3",
      "version": ">=1.26.0",
      "optional": false,
      "source": "pypi"
    }
  ],
  "homepage": "https://github.com/example/enhanced-http-node",
  "repository": "https://github.com/example/enhanced-http-node",
  "documentation": "https://docs.example.com/enhanced-http-node",
  "license": "MIT",
  "keywords": [
    "http",
    "api",
    "request",
    "network",
    "retry",
    "authentication",
    "validation"
  ],
  "category": "network",
  "icon": "http-icon.png",
  "screenshots": [
    "screenshot1.png",
    "screenshot2.png"
  ],
  "changelog": "CHANGELOG.md",
  "config_schema": {
    "type": "object",
    "properties": {
      "default_timeout": {
        "type": "integer",
        "title": "Default Timeout (seconds)",
        "description": "Default timeout for HTTP requests",
        "default": 30,
        "minimum": 1,
        "maximum": 300
      },
      "retry_attempts": {
        "type": "integer",
        "title": "Default Retry Attempts",
        "description": "Default number of retry attempts for failed requests",
        "default": 3,
        "minimum": 0,
        "maximum": 10
      },
      "enable_caching": {
        "type": "boolean",
        "title": "Enable Response Caching",
        "description": "Enable caching of GET responses",
        "default": false
      },
      "cache_ttl_seconds": {
        "type": "integer",
        "title": "Cache TTL (seconds)",
        "description": "Time-to-live for cached responses",
        "default": 300,
        "minimum": 60,
        "maximum": 3600
      }
    }
  },
  "default_config": {
    "default_timeout": 30,
    "retry_attempts": 3,
    "enable_caching": false,
    "cache_ttl_seconds": 300
  },
  "created_at": "2024-01-15T10:00:00Z",
  "updated_at": "2024-01-20T14:30:00Z"
}