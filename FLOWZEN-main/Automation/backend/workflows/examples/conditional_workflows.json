{
  "examples": [
    {
      "name": "Simple User Status Check",
      "description": "Basic IF/ELSE workflow that checks user status and sends different emails",
      "workflow": {
        "nodes": [
          {
            "id": "webhook_trigger_1",
            "type": "webhook_trigger",
            "label": "User Registration",
            "position": {"x": 100, "y": 100},
            "config": {
              "path": "/user/register",
              "method": "POST"
            }
          },
          {
            "id": "check_user_status",
            "type": "conditional",
            "label": "Check User Status",
            "position": {"x": 300, "y": 100},
            "config": {
              "left_operand": "user.status",
              "operator": "equals",
              "right_operand": "premium",
              "case_sensitive": true
            }
          },
          {
            "id": "send_premium_welcome",
            "type": "email_send",
            "label": "Send Premium Welcome",
            "position": {"x": 500, "y": 50},
            "config": {
              "to": "{{user.email}}",
              "subject": "Welcome to Premium!",
              "body": "Thank you for joining our premium service!"
            }
          },
          {
            "id": "send_standard_welcome",
            "type": "email_send", 
            "label": "Send Standard Welcome",
            "position": {"x": 500, "y": 150},
            "config": {
              "to": "{{user.email}}",
              "subject": "Welcome!",
              "body": "Thank you for joining our service!"
            }
          }
        ],
        "edges": [
          {
            "id": "edge_1",
            "source": "webhook_trigger_1",
            "target": "check_user_status"
          },
          {
            "id": "edge_2",
            "source": "check_user_status",
            "target": "send_premium_welcome",
            "condition": "true"
          },
          {
            "id": "edge_3",
            "source": "check_user_status",
            "target": "send_standard_welcome", 
            "condition": "false"
          }
        ]
      }
    },
    {
      "name": "Order Value Processing",
      "description": "Multi-condition workflow for order processing based on value and customer type",
      "workflow": {
        "nodes": [
          {
            "id": "order_webhook",
            "type": "webhook_trigger",
            "label": "Order Received",
            "position": {"x": 100, "y": 100},
            "config": {
              "path": "/order/received"
            }
          },
          {
            "id": "check_order_value",
            "type": "conditional",
            "label": "Check Order Value",
            "position": {"x": 300, "y": 100},
            "config": {
              "left_operand": "{{order.total}}",
              "operator": "greater_than",
              "right_operand": "1000",
              "case_sensitive": false
            }
          },
          {
            "id": "check_customer_type",
            "type": "conditional",
            "label": "Check Customer Type",
            "position": {"x": 500, "y": 50},
            "config": {
              "left_operand": "customer.type",
              "operator": "equals",
              "right_operand": "vip"
            }
          },
          {
            "id": "vip_high_value_processing",
            "type": "code",
            "label": "VIP High Value Processing",
            "position": {"x": 700, "y": 25},
            "config": {
              "code": "# Special VIP processing for high-value orders\nresult = {'priority': 'urgent', 'discount': 0.1, 'shipping': 'express'}"
            }
          },
          {
            "id": "regular_high_value_processing",
            "type": "code",
            "label": "Regular High Value Processing", 
            "position": {"x": 700, "y": 75},
            "config": {
              "code": "# Regular processing for high-value orders\nresult = {'priority': 'high', 'discount': 0.05, 'shipping': 'priority'}"
            }
          },
          {
            "id": "standard_processing",
            "type": "code",
            "label": "Standard Processing",
            "position": {"x": 500, "y": 150},
            "config": {
              "code": "# Standard order processing\nresult = {'priority': 'normal', 'discount': 0, 'shipping': 'standard'}"
            }
          },
          {
            "id": "send_confirmation",
            "type": "email_send",
            "label": "Send Order Confirmation",
            "position": {"x": 900, "y": 100},
            "config": {
              "to": "{{customer.email}}",
              "subject": "Order Confirmation #{{order.id}}",
              "body": "Your order has been processed with {{result.priority}} priority."
            }
          }
        ],
        "edges": [
          {
            "id": "edge_1",
            "source": "order_webhook",
            "target": "check_order_value"
          },
          {
            "id": "edge_2",
            "source": "check_order_value",
            "target": "check_customer_type",
            "condition": "true"
          },
          {
            "id": "edge_3",
            "source": "check_order_value",
            "target": "standard_processing",
            "condition": "false"
          },
          {
            "id": "edge_4",
            "source": "check_customer_type",
            "target": "vip_high_value_processing",
            "condition": "true"
          },
          {
            "id": "edge_5",
            "source": "check_customer_type",
            "target": "regular_high_value_processing",
            "condition": "false"
          },
          {
            "id": "edge_6",
            "source": "vip_high_value_processing",
            "target": "send_confirmation"
          },
          {
            "id": "edge_7",
            "source": "regular_high_value_processing",
            "target": "send_confirmation"
          },
          {
            "id": "edge_8",
            "source": "standard_processing",
            "target": "send_confirmation"
          }
        ]
      }
    },
    {
      "name": "Data Validation Workflow",
      "description": "Complex validation workflow using multiple operators",
      "workflow": {
        "nodes": [
          {
            "id": "data_input",
            "type": "manual_trigger",
            "label": "Data Input",
            "position": {"x": 100, "y": 100},
            "config": {
              "test_data": {
                "user": {
                  "email": "john@example.com",
                  "age": 25,
                  "country": "US",
                  "phone": "1234567890"
                }
              }
            }
          },
          {
            "id": "validate_email",
            "type": "conditional",
            "label": "Validate Email",
            "position": {"x": 300, "y": 50},
            "config": {
              "left_operand": "user.email",
              "operator": "contains",
              "right_operand": "@",
              "case_sensitive": false
            }
          },
          {
            "id": "validate_age",
            "type": "conditional",
            "label": "Validate Age",
            "position": {"x": 300, "y": 100},
            "config": {
              "left_operand": "{{user.age}}",
              "operator": "greater_equal",
              "right_operand": "18"
            }
          },
          {
            "id": "validate_country",
            "type": "conditional",
            "label": "Validate Country",
            "position": {"x": 300, "y": 150},
            "config": {
              "left_operand": "user.country",
              "operator": "in_list",
              "right_operand": "[\"US\", \"CA\", \"UK\", \"AU\"]"
            }
          },
          {
            "id": "validate_phone",
            "type": "conditional",
            "label": "Validate Phone",
            "position": {"x": 300, "y": 200},
            "config": {
              "left_operand": "user.phone",
              "operator": "regex_match",
              "right_operand": "^\\d{10}$"
            }
          },
          {
            "id": "all_valid",
            "type": "code",
            "label": "All Validations Passed",
            "position": {"x": 500, "y": 100},
            "config": {
              "code": "result = {'status': 'valid', 'message': 'All validations passed'}"
            }
          },
          {
            "id": "validation_failed",
            "type": "code",
            "label": "Validation Failed",
            "position": {"x": 500, "y": 200},
            "config": {
              "code": "result = {'status': 'invalid', 'message': 'One or more validations failed'}"
            }
          }
        ],
        "edges": [
          {
            "id": "edge_1",
            "source": "data_input",
            "target": "validate_email"
          },
          {
            "id": "edge_2",
            "source": "validate_email",
            "target": "validate_age",
            "condition": "true"
          },
          {
            "id": "edge_3",
            "source": "validate_email",
            "target": "validation_failed",
            "condition": "false"
          },
          {
            "id": "edge_4",
            "source": "validate_age",
            "target": "validate_country",
            "condition": "true"
          },
          {
            "id": "edge_5",
            "source": "validate_age",
            "target": "validation_failed",
            "condition": "false"
          },
          {
            "id": "edge_6",
            "source": "validate_country",
            "target": "validate_phone",
            "condition": "true"
          },
          {
            "id": "edge_7",
            "source": "validate_country",
            "target": "validation_failed",
            "condition": "false"
          },
          {
            "id": "edge_8",
            "source": "validate_phone",
            "target": "all_valid",
            "condition": "true"
          },
          {
            "id": "edge_9",
            "source": "validate_phone",
            "target": "validation_failed",
            "condition": "false"
          }
        ]
      }
    },
    {
      "name": "Chat Bot Decision Tree",
      "description": "Chatbot workflow with conditional responses based on user input",
      "workflow": {
        "nodes": [
          {
            "id": "chat_trigger",
            "type": "chat_trigger",
            "label": "Chat Message",
            "position": {"x": 100, "y": 100},
            "config": {
              "intent_extraction": true,
              "context_window": 5
            }
          },
          {
            "id": "check_greeting",
            "type": "conditional",
            "label": "Check for Greeting",
            "position": {"x": 300, "y": 50},
            "config": {
              "left_operand": "message",
              "operator": "regex_match",
              "right_operand": "(?i)\\b(hello|hi|hey|greetings)\\b",
              "case_sensitive": false
            }
          },
          {
            "id": "check_help_request",
            "type": "conditional",
            "label": "Check for Help Request",
            "position": {"x": 300, "y": 100},
            "config": {
              "left_operand": "message",
              "operator": "contains",
              "right_operand": "help",
              "case_sensitive": false
            }
          },
          {
            "id": "check_goodbye",
            "type": "conditional",
            "label": "Check for Goodbye",
            "position": {"x": 300, "y": 150},
            "config": {
              "left_operand": "message",
              "operator": "regex_match",
              "right_operand": "(?i)\\b(bye|goodbye|see you|farewell)\\b",
              "case_sensitive": false
            }
          },
          {
            "id": "greeting_response",
            "type": "chat_response",
            "label": "Greeting Response",
            "position": {"x": 500, "y": 50},
            "config": {
              "message_template": "Hello! How can I help you today?",
              "response_type": "text"
            }
          },
          {
            "id": "help_response",
            "type": "chat_response",
            "label": "Help Response",
            "position": {"x": 500, "y": 100},
            "config": {
              "message_template": "I can help you with account questions, order status, or general information. What would you like to know?",
              "response_type": "text"
            }
          },
          {
            "id": "goodbye_response",
            "type": "chat_response",
            "label": "Goodbye Response",
            "position": {"x": 500, "y": 150},
            "config": {
              "message_template": "Goodbye! Have a great day!",
              "response_type": "text"
            }
          },
          {
            "id": "default_response",
            "type": "chat_response",
            "label": "Default Response",
            "position": {"x": 500, "y": 200},
            "config": {
              "message_template": "I understand you said: '{{message}}'. Could you please be more specific about how I can help?",
              "response_type": "text"
            }
          }
        ],
        "edges": [
          {
            "id": "edge_1",
            "source": "chat_trigger",
            "target": "check_greeting"
          },
          {
            "id": "edge_2",
            "source": "check_greeting",
            "target": "greeting_response",
            "condition": "true"
          },
          {
            "id": "edge_3",
            "source": "check_greeting",
            "target": "check_help_request",
            "condition": "false"
          },
          {
            "id": "edge_4",
            "source": "check_help_request",
            "target": "help_response",
            "condition": "true"
          },
          {
            "id": "edge_5",
            "source": "check_help_request",
            "target": "check_goodbye",
            "condition": "false"
          },
          {
            "id": "edge_6",
            "source": "check_goodbye",
            "target": "goodbye_response",
            "condition": "true"
          },
          {
            "id": "edge_7",
            "source": "check_goodbye",
            "target": "default_response",
            "condition": "false"
          }
        ]
      }
    }
  ]
}