{
  "chat_intent_routing": {
    "name": "Chat Intent Routing",
    "description": "Route chat messages to different departments based on content analysis",
    "trigger": {
      "type": "chat_trigger",
      "params": {
        "session_timeout": 1800
      }
    },
    "nodes": {
      "intent_router": {
        "type": "router",
        "params": {
          "rules": [
            {
              "name": "billing",
              "left_operand": "{{input.text}}",
              "operator": "contains",
              "right_operand": "refund"
            },
            {
              "name": "billing", 
              "left_operand": "{{input.text}}",
              "operator": "contains",
              "right_operand": "payment"
            },
            {
              "name": "support",
              "left_operand": "{{input.text}}",
              "operator": "contains", 
              "right_operand": "bug"
            },
            {
              "name": "support",
              "left_operand": "{{input.text}}",
              "operator": "contains",
              "right_operand": "error"
            },
            {
              "name": "sales",
              "left_operand": "{{input.text}}",
              "operator": "contains",
              "right_operand": "pricing"
            },
            {
              "name": "sales",
              "left_operand": "{{input.text}}",
              "operator": "contains",
              "right_operand": "demo"
            }
          ],
          "default_path": "general",
          "case_sensitive": false,
          "evaluation_strategy": "first_match"
        }
      },
      "billing_response": {
        "type": "chat_response",
        "params": {
          "message": "I'll connect you with our billing department. They can help with refunds, payments, and account issues."
        }
      },
      "support_response": {
        "type": "chat_response", 
        "params": {
          "message": "I'll connect you with technical support. They can help troubleshoot bugs and errors."
        }
      },
      "sales_response": {
        "type": "chat_response",
        "params": {
          "message": "I'll connect you with our sales team. They can provide pricing information and schedule demos."
        }
      },
      "general_response": {
        "type": "chat_response",
        "params": {
          "message": "Thank you for your message. I'll connect you with our general support team."
        }
      }
    },
    "edges": [
      {
        "from": "chat_trigger",
        "to": "intent_router"
      },
      {
        "from": "intent_router",
        "to": "billing_response",
        "condition": "billing"
      },
      {
        "from": "intent_router", 
        "to": "support_response",
        "condition": "support"
      },
      {
        "from": "intent_router",
        "to": "sales_response", 
        "condition": "sales"
      },
      {
        "from": "intent_router",
        "to": "general_response",
        "condition": "general"
      }
    ]
  },

  "priority_routing": {
    "name": "Priority-Based Task Routing",
    "description": "Route tasks to different processing queues based on priority and type",
    "trigger": {
      "type": "webhook",
      "params": {
        "path": "/task-submit"
      }
    },
    "nodes": {
      "priority_router": {
        "type": "router",
        "params": {
          "rules": [
            {
              "name": "critical",
              "left_operand": "{{input.priority}}",
              "operator": "equals",
              "right_operand": "critical"
            },
            {
              "name": "urgent",
              "left_operand": "{{input.priority}}",
              "operator": "equals", 
              "right_operand": "urgent"
            },
            {
              "name": "high_volume",
              "left_operand": "{{input.batch_size}}",
              "operator": "greater_than",
              "right_operand": "100"
            }
          ],
          "default_path": "standard",
          "case_sensitive": true,
          "evaluation_strategy": "first_match"
        }
      },
      "critical_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/critical",
          "method": "POST",
          "timeout": 5
        }
      },
      "urgent_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/urgent", 
          "method": "POST",
          "timeout": 15
        }
      },
      "batch_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/batch",
          "method": "POST", 
          "timeout": 60
        }
      },
      "standard_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/standard",
          "method": "POST",
          "timeout": 30
        }
      }
    },
    "edges": [
      {
        "from": "webhook",
        "to": "priority_router"
      },
      {
        "from": "priority_router",
        "to": "critical_processor",
        "condition": "critical"
      },
      {
        "from": "priority_router",
        "to": "urgent_processor", 
        "condition": "urgent"
      },
      {
        "from": "priority_router",
        "to": "batch_processor",
        "condition": "high_volume"
      },
      {
        "from": "priority_router",
        "to": "standard_processor",
        "condition": "standard"
      }
    ]
  },

  "user_role_routing": {
    "name": "User Role-Based Access Routing",
    "description": "Route users to different workflows based on their role and permissions",
    "trigger": {
      "type": "webhook",
      "params": {
        "path": "/user-action"
      }
    },
    "nodes": {
      "role_router": {
        "type": "router",
        "params": {
          "rules": [
            {
              "name": "admin",
              "left_operand": "{{input.user.role}}",
              "operator": "equals",
              "right_operand": "admin"
            },
            {
              "name": "manager",
              "left_operand": "{{input.user.role}}",
              "operator": "equals",
              "right_operand": "manager"
            },
            {
              "name": "premium",
              "left_operand": "{{input.user.subscription}}",
              "operator": "equals",
              "right_operand": "premium"
            },
            {
              "name": "verified",
              "left_operand": "{{input.user.verified}}",
              "operator": "equals",
              "right_operand": "true"
            }
          ],
          "default_path": "basic",
          "case_sensitive": false,
          "evaluation_strategy": "first_match"
        }
      },
      "admin_workflow": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/admin/{{input.action}}",
          "method": "POST"
        }
      },
      "manager_workflow": {
        "type": "http_request", 
        "params": {
          "url": "https://api.internal.com/manager/{{input.action}}",
          "method": "POST"
        }
      },
      "premium_workflow": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/premium/{{input.action}}",
          "method": "POST"
        }
      },
      "verified_workflow": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/verified/{{input.action}}",
          "method": "POST"
        }
      },
      "basic_workflow": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/basic/{{input.action}}",
          "method": "POST"
        }
      }
    },
    "edges": [
      {
        "from": "webhook",
        "to": "role_router"
      },
      {
        "from": "role_router",
        "to": "admin_workflow",
        "condition": "admin"
      },
      {
        "from": "role_router",
        "to": "manager_workflow",
        "condition": "manager"
      },
      {
        "from": "role_router",
        "to": "premium_workflow",
        "condition": "premium"
      },
      {
        "from": "role_router",
        "to": "verified_workflow",
        "condition": "verified"
      },
      {
        "from": "role_router",
        "to": "basic_workflow",
        "condition": "basic"
      }
    ]
  },

  "content_type_routing": {
    "name": "Content Type Processing Router",
    "description": "Route different content types to specialized processing workflows",
    "trigger": {
      "type": "webhook",
      "params": {
        "path": "/content-upload"
      }
    },
    "nodes": {
      "content_router": {
        "type": "router",
        "params": {
          "rules": [
            {
              "name": "image",
              "left_operand": "{{input.content_type}}",
              "operator": "starts_with",
              "right_operand": "image/"
            },
            {
              "name": "video",
              "left_operand": "{{input.content_type}}",
              "operator": "starts_with", 
              "right_operand": "video/"
            },
            {
              "name": "document",
              "left_operand": "{{input.content_type}}",
              "operator": "in_list",
              "right_operand": "[\"application/pdf\", \"application/msword\", \"text/plain\"]"
            },
            {
              "name": "large_file",
              "left_operand": "{{input.file_size}}",
              "operator": "greater_than",
              "right_operand": "10485760"
            }
          ],
          "default_path": "generic",
          "case_sensitive": false,
          "evaluation_strategy": "first_match"
        }
      },
      "image_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/image",
          "method": "POST"
        }
      },
      "video_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/video",
          "method": "POST"
        }
      },
      "document_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/document",
          "method": "POST"
        }
      },
      "large_file_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/large-file",
          "method": "POST"
        }
      },
      "generic_processor": {
        "type": "http_request",
        "params": {
          "url": "https://api.internal.com/process/generic",
          "method": "POST"
        }
      }
    },
    "edges": [
      {
        "from": "webhook",
        "to": "content_router"
      },
      {
        "from": "content_router",
        "to": "image_processor",
        "condition": "image"
      },
      {
        "from": "content_router",
        "to": "video_processor",
        "condition": "video"
      },
      {
        "from": "content_router",
        "to": "document_processor",
        "condition": "document"
      },
      {
        "from": "content_router",
        "to": "large_file_processor",
        "condition": "large_file"
      },
      {
        "from": "content_router",
        "to": "generic_processor",
        "condition": "generic"
      }
    ]
  }
}