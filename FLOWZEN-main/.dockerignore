# Docker ignore file for Django Automation Platform
# Only include necessary files for the Docker build

# Git and version control
.git
.gitignore

# Python
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
.Python
**/.venv
**/venv/
**/env/

# Django
**/db.sqlite3
**/media/
**/staticfiles/

# Development files
**/.env*
**/.DS_Store
**/.vscode
**/.idea
**/node_modules

# Documentation and markdown files (not needed in container)
**/*.md
docs/
scripts/

# Frontend build artifacts (not needed for backend container)
# Automation/frontend/  # REMOVED: We need frontend files now
# frontend/             # REMOVED: We need frontend files now

# Docker files (avoid recursion)
**/Dockerfile*
**/docker-compose*
**/compose.y*ml

# Test files
**/test_*
**/*_test.py
**/tests/

# Logs
**/*.log

# OS files
**/.DS_Store
**/Thumbs.db
