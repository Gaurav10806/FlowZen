{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Node Schema",
  "description": "JSON schema for node definitions in the automation platform",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["trigger", "action", "utility"],
      "description": "Category of the node"
    },
    "action_type": {
      "type": "string",
      "description": "Specific node implementation identifier"
    },
    "name": {
      "type": "string",
      "description": "Display name of the node type"
    },
    "description": {
      "type": "string",
      "description": "Description of what the node does"
    },
    "icon": {
      "type": "string",
      "description": "Icon identifier for the node"
    },
    "category": {
      "type": "string",
      "description": "Category for grouping nodes in the palette"
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/parameter"
      },
      "description": "Configuration parameters for the node"
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/output"
      },
      "description": "Output definitions for the node"
    }
  },
  "required": ["type", "action_type", "name"],
  "definitions": {
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name"
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "array", "object", "credential"],
          "description": "Parameter data type"
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "Whether the parameter is required"
        },
        "default": {
          "description": "Default value for the parameter"
        },
        "description": {
          "type": "string",
          "description": "Parameter description"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "value": {}
            }
          },
          "description": "Available options for select parameters"
        }
      },
      "required": ["name", "type"]
    },
    "output": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Output name"
        },
        "type": {
          "type": "string",
          "description": "Output data type"
        },
        "description": {
          "type": "string",
          "description": "Output description"
        }
      },
      "required": ["name", "type"]
    }
  }
}