{
  "intelligent_customer_support": {
    "name": "Intelligent Customer Support Agent",
    "description": "AI-powered customer support with memory, tool usage, and safety controls",
    "trigger": {
      "type": "chat_trigger",
      "params": {
        "channel": "customer_support"
      }
    },
    "nodes": {
      "support_agent": {
        "type": "ai_agent",
        "params": {
          "goal": "Provide helpful customer support by understanding the issue, using available tools to gather information, and providing accurate solutions",
          "reasoning_mode": "conversational",
          "available_tools": ["search_knowledge_base", "check_order_status", "create_ticket", "send_email"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 8,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.3,
            "max_tokens": 1500
          }
        }
      },
      "search_knowledge_base": {
        "type": "http_request",
        "params": {
          "url": "https://api.company.com/kb/search",
          "method": "POST",
          "headers": {
            "Authorization": "Bearer {{credentials.kb_token}}"
          },
          "body": {
            "query": "{{search_query}}",
            "limit": 5
          }
        }
      },
      "check_order_status": {
        "type": "http_request",
        "params": {
          "url": "https://api.company.com/orders/{{order_id}}",
          "method": "GET",
          "headers": {
            "Authorization": "Bearer {{credentials.orders_token}}"
          }
        }
      },
      "create_ticket": {
        "type": "http_request",
        "params": {
          "url": "https://api.company.com/tickets",
          "method": "POST",
          "headers": {
            "Authorization": "Bearer {{credentials.tickets_token}}"
          },
          "body": {
            "title": "{{ticket_title}}",
            "description": "{{ticket_description}}",
            "priority": "{{priority}}",
            "customer_id": "{{customer_id}}"
          }
        }
      },
      "validate_response": {
        "type": "ai_validation",
        "params": {
          "content_field": "agent_execution.final_answer",
          "validation_strategies": ["content_safety", "business_rules"],
          "safety_level": "moderate",
          "custom_rules": [
            {
              "name": "no_competitor_mention",
              "type": "business",
              "rule_type": "no_competitor_mention",
              "competitors": ["CompetitorA", "CompetitorB"]
            },
            {
              "name": "required_disclaimer",
              "type": "business",
              "rule_type": "required_disclaimer",
              "disclaimer": "For additional help, contact support@company.com"
            }
          ],
          "fail_on_violation": false
        }
      },
      "apply_guardrails": {
        "type": "ai_guardrail",
        "params": {
          "guardrail_types": ["content_filter", "output_modifier"],
          "content_filters": {
            "content_fields": ["agent_execution.final_answer"],
            "forbidden_words": ["damn", "hell"],
            "replacement": "[filtered]"
          },
          "modification_rules": {
            "target_fields": ["agent_execution.final_answer"],
            "add_disclaimer": true,
            "disclaimer_text": "This response was generated by our AI assistant. For complex issues, please contact human support.",
            "max_length": 2000
          }
        }
      },
      "send_response": {
        "type": "chat_response",
        "params": {
          "response_text": "{{agent_execution.final_answer}}",
          "response_type": "text"
        }
      }
    },
    "edges": [
      {
        "from": "chat_trigger",
        "to": "support_agent"
      },
      {
        "from": "support_agent",
        "to": "validate_response"
      },
      {
        "from": "validate_response",
        "to": "apply_guardrails"
      },
      {
        "from": "apply_guardrails",
        "to": "send_response"
      }
    ]
  },

  "content_creation_pipeline": {
    "name": "AI Content Creation with Review Pipeline",
    "description": "Automated content creation with AI planning, generation, and multi-stage validation",
    "trigger": {
      "type": "webhook",
      "params": {
        "path": "/create-content"
      }
    },
    "nodes": {
      "content_planner": {
        "type": "ai_agent",
        "params": {
          "goal": "Create a detailed content plan based on the brief, including structure, key points, and tone",
          "reasoning_mode": "planning",
          "available_tools": ["research_topics", "analyze_competitors"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 5,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.7,
            "max_tokens": 2000
          }
        }
      },
      "research_topics": {
        "type": "http_request",
        "params": {
          "url": "https://api.research.com/topics",
          "method": "POST",
          "body": {
            "query": "{{research_query}}",
            "depth": "comprehensive"
          }
        }
      },
      "analyze_competitors": {
        "type": "http_request",
        "params": {
          "url": "https://api.competitor-analysis.com/analyze",
          "method": "POST",
          "body": {
            "topic": "{{topic}}",
            "competitors": "{{competitors}}"
          }
        }
      },
      "content_generator": {
        "type": "ai_agent",
        "params": {
          "goal": "Generate high-quality content based on the approved plan, following brand guidelines and SEO best practices",
          "reasoning_mode": "analytical",
          "available_tools": ["check_seo_keywords", "verify_facts"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 10,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.6,
            "max_tokens": 3000
          }
        }
      },
      "check_seo_keywords": {
        "type": "http_request",
        "params": {
          "url": "https://api.seo-tools.com/keywords/check",
          "method": "POST",
          "body": {
            "content": "{{content}}",
            "target_keywords": "{{keywords}}"
          }
        }
      },
      "verify_facts": {
        "type": "http_request",
        "params": {
          "url": "https://api.fact-checker.com/verify",
          "method": "POST",
          "body": {
            "claims": "{{claims}}"
          }
        }
      },
      "content_validator": {
        "type": "ai_validation",
        "params": {
          "content_field": "agent_execution.final_answer",
          "validation_strategies": ["content_safety", "factual_accuracy", "format_compliance", "business_rules"],
          "safety_level": "strict",
          "custom_rules": [
            {
              "name": "word_count",
              "type": "custom",
              "rule_type": "word_count",
              "min_words": 500,
              "max_words": 2000
            },
            {
              "name": "brand_consistency",
              "type": "business",
              "rule_type": "brand_consistency",
              "brand_terms": ["Our Company", "Our Product"],
              "incorrect_terms": ["we", "us", "our company"]
            },
            {
              "name": "required_sections",
              "type": "format",
              "rule_type": "required_pattern",
              "pattern": "(Introduction|Conclusion)"
            }
          ],
          "fail_on_violation": true
        }
      },
      "quality_guardrails": {
        "type": "ai_guardrail",
        "params": {
          "guardrail_types": ["content_filter", "output_modifier", "cost_monitor"],
          "content_filters": {
            "content_fields": ["agent_execution.final_answer"],
            "remove_urls": false,
            "remove_emails": true
          },
          "modification_rules": {
            "target_fields": ["agent_execution.final_answer"],
            "add_disclaimer": true,
            "disclaimer_text": "This content was generated with AI assistance and reviewed for quality.",
            "safety_keywords": ["medical", "legal", "financial"],
            "safety_warning": "Please consult with relevant professionals for specific advice."
          },
          "cost_limits": {
            "max_cost_per_request": 2.0,
            "daily_cost_limit": 50.0
          }
        }
      },
      "publish_content": {
        "type": "http_request",
        "params": {
          "url": "https://api.cms.com/content",
          "method": "POST",
          "headers": {
            "Authorization": "Bearer {{credentials.cms_token}}"
          },
          "body": {
            "title": "{{content_title}}",
            "content": "{{agent_execution.final_answer}}",
            "status": "draft",
            "author": "AI Assistant"
          }
        }
      }
    },
    "edges": [
      {
        "from": "webhook",
        "to": "content_planner"
      },
      {
        "from": "content_planner",
        "to": "content_generator"
      },
      {
        "from": "content_generator",
        "to": "content_validator"
      },
      {
        "from": "content_validator",
        "to": "quality_guardrails"
      },
      {
        "from": "quality_guardrails",
        "to": "publish_content"
      }
    ]
  },

  "intelligent_data_analysis": {
    "name": "Intelligent Data Analysis Agent",
    "description": "AI agent that analyzes data, generates insights, and creates reports with safety validation",
    "trigger": {
      "type": "webhook",
      "params": {
        "path": "/analyze-data"
      }
    },
    "nodes": {
      "data_analyzer": {
        "type": "ai_agent",
        "params": {
          "goal": "Analyze the provided data to identify patterns, trends, and actionable insights",
          "reasoning_mode": "analytical",
          "available_tools": ["fetch_data", "run_statistics", "create_visualization", "validate_insights"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 15,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.2,
            "max_tokens": 3000
          }
        }
      },
      "fetch_data": {
        "type": "http_request",
        "params": {
          "url": "https://api.datawarehouse.com/query",
          "method": "POST",
          "headers": {
            "Authorization": "Bearer {{credentials.data_token}}"
          },
          "body": {
            "query": "{{sql_query}}",
            "format": "json"
          }
        }
      },
      "run_statistics": {
        "type": "code",
        "params": {
          "language": "python",
          "code": "# Statistical analysis\nimport pandas as pd\nimport numpy as np\nfrom scipy import stats\n\n# Process data and calculate statistics\nresult = {'mean': np.mean(data), 'std': np.std(data), 'correlation': stats.pearsonr(x, y)}\nreturn result"
        }
      },
      "create_visualization": {
        "type": "http_request",
        "params": {
          "url": "https://api.charts.com/create",
          "method": "POST",
          "body": {
            "data": "{{chart_data}}",
            "type": "{{chart_type}}",
            "title": "{{chart_title}}"
          }
        }
      },
      "validate_insights": {
        "type": "ai_validation",
        "params": {
          "content_field": "agent_execution.final_answer",
          "validation_strategies": ["factual_accuracy", "format_compliance"],
          "safety_level": "strict",
          "custom_rules": [
            {
              "name": "statistical_claims",
              "type": "custom",
              "rule_type": "regex_match",
              "pattern": "(correlation|significant|p-value|confidence)",
              "should_match": true
            },
            {
              "name": "data_source_citation",
              "type": "format",
              "rule_type": "required_pattern",
              "pattern": "(Source:|Data from:)"
            }
          ],
          "fail_on_violation": false
        }
      },
      "analysis_guardrails": {
        "type": "ai_guardrail",
        "params": {
          "guardrail_types": ["output_modifier", "cost_monitor"],
          "modification_rules": {
            "target_fields": ["agent_execution.final_answer"],
            "add_disclaimer": true,
            "disclaimer_text": "This analysis was generated by AI. Please validate findings with domain experts.",
            "safety_keywords": ["prediction", "forecast", "recommendation"],
            "safety_warning": "These insights are based on historical data and should be validated before making business decisions."
          },
          "cost_limits": {
            "max_cost_per_request": 5.0
          }
        }
      },
      "generate_report": {
        "type": "http_request",
        "params": {
          "url": "https://api.reports.com/generate",
          "method": "POST",
          "body": {
            "title": "Data Analysis Report",
            "content": "{{agent_execution.final_answer}}",
            "format": "pdf",
            "template": "analysis_template"
          }
        }
      }
    },
    "edges": [
      {
        "from": "webhook",
        "to": "data_analyzer"
      },
      {
        "from": "data_analyzer",
        "to": "validate_insights"
      },
      {
        "from": "validate_insights",
        "to": "analysis_guardrails"
      },
      {
        "from": "analysis_guardrails",
        "to": "generate_report"
      }
    ]
  },

  "smart_email_assistant": {
    "name": "Smart Email Assistant with Context",
    "description": "AI assistant that drafts emails with context awareness and safety validation",
    "trigger": {
      "type": "webhook",
      "params": {
        "path": "/draft-email"
      }
    },
    "nodes": {
      "email_drafter": {
        "type": "ai_agent",
        "params": {
          "goal": "Draft a professional email based on the request, considering context, tone, and recipient",
          "reasoning_mode": "conversational",
          "available_tools": ["check_contact_history", "get_template", "verify_recipient"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 6,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.4,
            "max_tokens": 1500
          }
        }
      },
      "check_contact_history": {
        "type": "http_request",
        "params": {
          "url": "https://api.crm.com/contacts/{{contact_email}}/history",
          "method": "GET",
          "headers": {
            "Authorization": "Bearer {{credentials.crm_token}}"
          }
        }
      },
      "get_template": {
        "type": "http_request",
        "params": {
          "url": "https://api.templates.com/email/{{template_type}}",
          "method": "GET"
        }
      },
      "verify_recipient": {
        "type": "http_request",
        "params": {
          "url": "https://api.email-validator.com/verify",
          "method": "POST",
          "body": {
            "email": "{{recipient_email}}"
          }
        }
      },
      "email_validator": {
        "type": "ai_validation",
        "params": {
          "content_field": "agent_execution.final_answer",
          "validation_strategies": ["content_safety", "business_rules", "format_compliance"],
          "safety_level": "moderate",
          "custom_rules": [
            {
              "name": "professional_tone",
              "type": "business",
              "rule_type": "no_competitor_mention",
              "competitors": []
            },
            {
              "name": "email_structure",
              "type": "format",
              "rule_type": "required_pattern",
              "pattern": "(Dear|Hello|Hi).*(Sincerely|Best regards|Thank you)"
            },
            {
              "name": "length_check",
              "type": "custom",
              "rule_type": "word_count",
              "min_words": 20,
              "max_words": 500
            }
          ],
          "fail_on_violation": false
        }
      },
      "email_guardrails": {
        "type": "ai_guardrail",
        "params": {
          "guardrail_types": ["content_filter", "output_modifier"],
          "content_filters": {
            "content_fields": ["agent_execution.final_answer"],
            "remove_emails": false,
            "forbidden_words": ["urgent", "ASAP", "immediately"]
          },
          "modification_rules": {
            "target_fields": ["agent_execution.final_answer"],
            "add_disclaimer": true,
            "disclaimer_text": "This email was drafted by AI. Please review before sending.",
            "max_length": 2000
          }
        }
      },
      "save_draft": {
        "type": "http_request",
        "params": {
          "url": "https://api.email.com/drafts",
          "method": "POST",
          "headers": {
            "Authorization": "Bearer {{credentials.email_token}}"
          },
          "body": {
            "to": "{{recipient_email}}",
            "subject": "{{email_subject}}",
            "body": "{{agent_execution.final_answer}}",
            "status": "draft"
          }
        }
      }
    },
    "edges": [
      {
        "from": "webhook",
        "to": "email_drafter"
      },
      {
        "from": "email_drafter",
        "to": "email_validator"
      },
      {
        "from": "email_validator",
        "to": "email_guardrails"
      },
      {
        "from": "email_guardrails",
        "to": "save_draft"
      }
    ]
  },

  "parallel_ai_research": {
    "name": "Parallel AI Research and Synthesis",
    "description": "Multiple AI agents research different aspects in parallel, then synthesize findings",
    "trigger": {
      "type": "webhook",
      "params": {
        "path": "/research-topic"
      }
    },
    "nodes": {
      "research_coordinator": {
        "type": "ai_agent",
        "params": {
          "goal": "Coordinate research by breaking down the topic into specific research areas",
          "reasoning_mode": "planning",
          "available_tools": [],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 3,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.5,
            "max_tokens": 1000
          }
        }
      },
      "research_fork": {
        "type": "parallel_fork",
        "params": {
          "branch_count": 3,
          "branch_names": ["technical_research", "market_research", "competitive_research"],
          "execution_mode": "async",
          "timeout_ms": 60000,
          "failure_strategy": "continue_on_error"
        }
      },
      "technical_researcher": {
        "type": "ai_agent",
        "params": {
          "goal": "Research technical aspects, implementation details, and technical feasibility",
          "reasoning_mode": "analytical",
          "available_tools": ["search_technical_docs", "analyze_code_repos"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 8,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.3,
            "max_tokens": 2000
          }
        }
      },
      "market_researcher": {
        "type": "ai_agent",
        "params": {
          "goal": "Research market trends, opportunities, and business implications",
          "reasoning_mode": "analytical",
          "available_tools": ["search_market_data", "analyze_trends"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 8,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.3,
            "max_tokens": 2000
          }
        }
      },
      "competitive_researcher": {
        "type": "ai_agent",
        "params": {
          "goal": "Research competitive landscape, alternatives, and positioning",
          "reasoning_mode": "analytical",
          "available_tools": ["search_competitors", "analyze_positioning"],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 8,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.3,
            "max_tokens": 2000
          }
        }
      },
      "research_merge": {
        "type": "parallel_merge",
        "params": {
          "merge_strategy": "all",
          "merge_mode": "object",
          "timeout_ms": 90000,
          "failure_strategy": "partial_success"
        }
      },
      "research_synthesizer": {
        "type": "ai_agent",
        "params": {
          "goal": "Synthesize all research findings into a comprehensive report with insights and recommendations",
          "reasoning_mode": "analytical",
          "available_tools": [],
          "memory_enabled": true,
          "safety_level": "moderate",
          "max_steps": 10,
          "model_config": {
            "model": "gpt-4",
            "temperature": 0.4,
            "max_tokens": 3000
          }
        }
      },
      "research_validator": {
        "type": "ai_validation",
        "params": {
          "content_field": "agent_execution.final_answer",
          "validation_strategies": ["factual_accuracy", "format_compliance"],
          "safety_level": "moderate",
          "custom_rules": [
            {
              "name": "comprehensive_coverage",
              "type": "format",
              "rule_type": "required_pattern",
              "pattern": "(Technical|Market|Competitive)"
            },
            {
              "name": "report_structure",
              "type": "format",
              "rule_type": "required_pattern",
              "pattern": "(Summary|Findings|Recommendations)"
            }
          ],
          "fail_on_violation": false
        }
      }
    },
    "edges": [
      {
        "from": "webhook",
        "to": "research_coordinator"
      },
      {
        "from": "research_coordinator",
        "to": "research_fork"
      },
      {
        "from": "research_fork",
        "to": "technical_researcher",
        "condition": "technical_research"
      },
      {
        "from": "research_fork",
        "to": "market_researcher",
        "condition": "market_research"
      },
      {
        "from": "research_fork",
        "to": "competitive_researcher",
        "condition": "competitive_research"
      },
      {
        "from": "technical_researcher",
        "to": "research_merge",
        "condition": "technical_research"
      },
      {
        "from": "market_researcher",
        "to": "research_merge",
        "condition": "market_research"
      },
      {
        "from": "competitive_researcher",
        "to": "research_merge",
        "condition": "competitive_research"
      },
      {
        "from": "research_merge",
        "to": "research_synthesizer"
      },
      {
        "from": "research_synthesizer",
        "to": "research_validator"
      }
    ]
  }
}