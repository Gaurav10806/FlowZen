# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env and configure all values for production deployment

# ================================
# CRITICAL SECURITY SETTINGS
# ================================

# Django secret key - MUST be unique and secure (min 50 characters)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-super-secret-key-here-minimum-50-characters-long

# Debug mode - MUST be False in production
DJANGO_DEBUG=False

# Allowed hosts - comma-separated list of domains
DJANGO_ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com,www.yourdomain.com

# ================================
# DATABASE CONFIGURATION
# ================================

# PostgreSQL database settings
DATABASE_NAME=automation_production
DATABASE_USER=automation_user
DATABASE_PASSWORD=super-secure-database-password-here
DATABASE_HOST=db.internal.yourdomain.com
DATABASE_PORT=5432

# Database security
DATABASE_SSL_MODE=require
DATABASE_POOL_ENABLED=True

# ================================
# ENCRYPTION KEYS
# ================================

# Master key for credential encryption
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
CREDENTIALS_MASTER_KEY=your-fernet-encryption-key-here

# Field-level encryption key
FIELD_ENCRYPTION_KEY=your-field-encryption-key-here

# Backup encryption key
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key-here

# ================================
# REDIS & CELERY
# ================================

# Redis connection for cache and Celery
REDIS_URL=redis://redis.internal.yourdomain.com:6379/0

# Celery broker and result backend
CELERY_BROKER_URL=redis://redis.internal.yourdomain.com:6379/0
CELERY_RESULT_BACKEND=redis://redis.internal.yourdomain.com:6379/0

# ================================
# EXTERNAL SERVICES
# ================================

# Email configuration
EMAIL_HOST=smtp.yourdomain.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Automation Platform <noreply@yourdomain.com>

# Monitoring and error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Prometheus metrics
PROMETHEUS_METRICS_ENABLED=True
PROMETHEUS_METRICS_PORT=8001

# ================================
# SECURITY FEATURES
# ================================

# Webhook security
WEBHOOK_SIGNATURE_REQUIRED=True
WEBHOOK_IP_ALLOWLIST_ENABLED=True

# Rate limiting
RATE_LIMITING_ENABLED=True
RATE_LIMIT_REDIS_URL=redis://redis.internal.yourdomain.com:6379/1

# IP allowlist enforcement
IP_ALLOWLIST_ENABLED=True

# CSRF protection
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ================================
# COMPLIANCE & AUDIT
# ================================

# GDPR compliance
GDPR_COMPLIANCE_ENABLED=True
DATA_RETENTION_DAYS=365

# Audit logging
AUDIT_LOGGING_ENABLED=True
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years

# Backup settings
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ================================
# PERFORMANCE SETTINGS
# ================================

# Cache timeout
CACHE_TIMEOUT=300

# Database connection pooling
DB_CONN_MAX_AGE=60
DB_MAX_CONNECTIONS=20

# Celery worker settings
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# ================================
# LOGGING CONFIGURATION
# ================================

# Log levels
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARNING
AUDIT_LOG_LEVEL=INFO

# Log file paths
LOG_DIR=/var/log/automation
DJANGO_LOG_FILE=/var/log/automation/django.log
SECURITY_LOG_FILE=/var/log/automation/security.log
AUDIT_LOG_FILE=/var/log/automation/audit.log

# ================================
# ALERTING CONFIGURATION
# ================================

# Email alerts
ALERT_EMAIL=admin@yourdomain.com

# Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# PagerDuty integration
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-integration-key

# ================================
# OPTIONAL INTEGRATIONS
# ================================

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# OpenAI (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# AWS (for cloud integrations)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1

# HashiCorp Vault (for advanced secret management)
VAULT_URL=https://vault.internal.yourdomain.com
VAULT_TOKEN=your-vault-token

# ================================
# DEVELOPMENT OVERRIDES
# ================================

# Set to True only for development/staging
DJANGO_DB_SQLITE=False
CELERY_TASK_ALWAYS_EAGER=False

# ================================
# HEALTH CHECK CONFIGURATION
# ================================

# Health check endpoints
HEALTH_CHECK_ENABLED=True
HEALTH_CHECK_DATABASE=True
HEALTH_CHECK_CACHE=True
HEALTH_CHECK_CELERY=True

# ================================
# STATIC FILES & MEDIA
# ================================

# Static files (served by CDN in production)
STATIC_URL=/static/
STATIC_ROOT=/var/www/automation/static

# Media files
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/automation/media

# CDN configuration (optional)
CDN_URL=https://cdn.yourdomain.com

# ================================
# TIMEZONE & LOCALIZATION
# ================================

TIME_ZONE=UTC
USE_TZ=True
LANGUAGE_CODE=en-us